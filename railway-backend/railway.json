{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install -g openwork-orchestrator && curl -fsSL https://opencode.ai/install | bash -s -- --no-modify-path"
  },
  "deploy": {
    "startCommand": "openwork start --workspace /app/workspace --approval auto --port $PORT --hostname 0.0.0.0",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
