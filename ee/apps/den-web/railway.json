{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "packaging/docker/Dockerfile.den-web",
    "watchPatterns": ["ee/apps/den-web/**", "ee/packages/**", "packages/**"]
  },
  "deploy": {
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
